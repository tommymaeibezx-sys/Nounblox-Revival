Options -Indexes
RewriteEngine On

# 1. Si existe archivo o carpeta, usarlo
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 2. Quitar extensiones falsas (.aspx, .html, .ashx)
RewriteRule ^(.*)\.(aspx|ashx|html)$ /$1 [R=301,L,NC]

# 3. Rutas específicas importantes
RewriteRule ^games$ Games.php [L]
RewriteRule ^$ Games.php [L]

# 4. TODO lo demás (opcional fallback seguro)
RewriteRule ^(.*)$ Games.php [L]
