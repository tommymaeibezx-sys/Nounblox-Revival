Options -Indexes
RewriteEngine On

# Si el archivo o carpeta existe físicamente, servirlo normal
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Quitar extensiones visibles (.aspx, .ashx, .html)
RewriteRule ^(.*)\.(aspx|ashx|html)$ $1 [L,NC]

# 🔥 TODO lo demás va a Games.php
RewriteRule ^.*$ /Games.php [L]
